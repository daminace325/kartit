# =============================================================================
# apps/worker/.env.example — template for apps/worker/.env
# Copy to `.env` and fill in values for your environment.
# =============================================================================

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development

# --- Database --------------------------------------------------------------
# Local: matches docker-compose Postgres.
# Render: use the "Internal Database URL" from your Render Postgres instance.
DATABASE_URL=postgresql://ecomm:change-me-locally@localhost:5432/ecomm

# --- Redis -----------------------------------------------------------------
# Local: matches docker-compose Redis.
# Render: use the "Internal Redis URL" from your Render Redis instance.
REDIS_URL=redis://localhost:6379

# --- Stripe ----------------------------------------------------------------
# Required for the reconciliation worker (P2.5). Uses the same test/live key
# as the API — copy from apps/api/.env.
STRIPE_SECRET_KEY=
