# =============================================================================
# apps/api/.env — used by `npm run dev` (ts-node-dev) and `npm run start`.
# Copy this to `.env` for local development. In production set every value
# below in the Render dashboard (Environment tab).
# =============================================================================

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
# Render injects PORT automatically; set explicitly only for local.
PORT=5000

# --- Database --------------------------------------------------------------
# Local: matches docker-compose Postgres.
# Render: use the "Internal Database URL" from your Render Postgres instance.
DATABASE_URL=postgresql://ecomm:change-me-locally@localhost:5432/ecomm

# --- Auth ------------------------------------------------------------------
# Production MUST be 32+ random bytes (e.g. `openssl rand -hex 32`).
JWT_SECRET=dev-only-change-me-please-use-32-plus-random-bytes
JWT_EXPIRES_IN=7d
COOKIE_NAME=ecomm_auth
# Local dev (http): false / lax. Production (https + cross-site): true / none.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- CORS ------------------------------------------------------------------
# Comma-separated list of allowed web origins. Supports a single `*` wildcard
# in the host part (e.g. https://*.vercel.app) for preview deployments.
WEB_ORIGINS=http://localhost:3000

# --- Cloudinary ------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=ecomm/products

# --- Stripe ----------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=USD
