{
  "name": "ecomm-main",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=20.19 <23"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "build:packages": "npm run build --workspace=packages/shared && npm run build --workspace=packages/db",
    "build:web": "npm run build:packages && npm run build --workspace=apps/web",
    "build:api": "npm run build:packages && npm run build --workspace=apps/api",
    "build": "npm run build:api && npm run build:web",
    "start:web": "npm run start --workspace=apps/web",
    "start:api": "npm run start --workspace=apps/api",
    "db:generate": "npm run generate --workspace=packages/db",
    "db:migrate:dev": "npm run migrate --workspace=packages/db",
    "db:migrate:deploy": "npm run migrate:deploy --workspace=packages/db",
    "db:seed": "npm run seed --workspace=packages/db",
    "db:studio": "npm run studio --workspace=packages/db",
    "job:sweep": "ts-node apps/api/src/jobs/sweepAbandonedOrders.ts",
    "typecheck": "tsc -p apps/api/tsconfig.json --noEmit && tsc -p apps/web/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "typescript": "^5"
  }
}
