# =============================================================================
# Root .env — used by docker-compose AND root-level Prisma CLI commands.
# Copy this to `.env` and fill in real values for local development.
# In production these vars live in Render (api) / your DB host — NOT here.
# =============================================================================

# Postgres credentials (consumed by docker-compose.yml)
POSTGRES_USER=ecomm
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=ecomm

# Connection string used by `prisma migrate` / `prisma studio` from the repo root.
# Must match the POSTGRES_* values above when using docker-compose.
DATABASE_URL=postgresql://ecomm:change-me-locally@localhost:5432/ecomm

# Redis — used by the API for caching and session state (ioredis).
REDIS_URL=redis://localhost:6379
