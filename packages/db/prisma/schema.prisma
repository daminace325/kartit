// Prisma schema for ecomm — Phase 1 (minimal)
// Money is stored as BigInt minor units (e.g. 1999 = $19.99) + ISO currency code.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ─────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  FAILED
  REFUNDED
}

enum PaymentStatus {
  REQUIRES_PAYMENT
  SUCCEEDED
  FAILED
  REFUNDED
}

enum RefundRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum IdempotencyStatus {
  IN_PROGRESS
  COMPLETED
}

enum OutboxStatus {
  PENDING
  SENT
  FAILED
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

// ─── Models ────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique @db.Citext
  passwordHash String
  name         String?
  role         UserRole @default(CUSTOMER)
  tokenVersion Int      @default(0) // bump to invalidate all outstanding sessions
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cart           Cart?
  orders         Order[]
  addresses      Address[]
  refundRequests        RefundRequest[] @relation("UserRefundRequests")
  reviewedRefundRequests RefundRequest[] @relation("ReviewedByUser")
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String
  country    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Category {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  parentId  String?
  parent    Category?  @relation("CategoryToSubcategory", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryToSubcategory")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  isActive   Boolean   @default(true)

  products Product[]

  @@index([parentId])
  @@index([deletedAt])
  @@index([isActive])
}

model Product {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String
  priceMinor  BigInt
  currency    String    @db.Char(3)
  stock       Int       @default(0)
  isActive    Boolean   @default(true)
  sku         String    @unique
  deletedAt   DateTime?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images     ProductImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([isActive])
  @@index([deletedAt])
  @@index([createdAt, id])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  publicId  String
  alt       String?
  position  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, position])
  @@index([productId])
}

model Cart {
  id     String     @id @default(cuid())
  userId String     @unique
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  status        OrderStatus @default(PENDING)
  subtotalMinor BigInt
  shippingMinor BigInt      @default(0)
  taxMinor      BigInt      @default(0)
  discountMinor BigInt      @default(0)
  totalMinor    BigInt
  currency      String      @db.Char(3)
  promotionId   String?
  promotion     Promotion?  @relation(fields: [promotionId], references: [id])
  promotionCode String?
  shippingName       String
  shippingPhone      String
  shippingLine1      String
  shippingLine2      String?
  shippingCity       String
  shippingState      String?
  shippingPostalCode String
  shippingCountry    String

  items         OrderItem[]
  payments      Payment[]
  refundRequest RefundRequest?

  paidAt      DateTime?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt, id])
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  // Snapshot fields so future product changes don't alter past orders
  productName    String
  productSlug    String
  imageUrl       String?
  unitPriceMinor BigInt
  currency       String  @db.Char(3)
  quantity       Int
  totalMinor     BigInt

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  providerPaymentId String?       @unique // Stripe PaymentIntent id
  status            PaymentStatus @default(REQUIRES_PAYMENT)
  amountMinor       BigInt
  currency          String        @db.Char(3)
  failureReason     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
}

// Idempotency-Key store for state-changing endpoints (P1.1).
// Scoped per (userId, key); requestHash binds the key to the original payload
// so accidental reuse with a different body returns 409 instead of replaying.
// Hot-path moves to Redis in P2.2; this Postgres table remains the durable
// fallback / promotion target.
model IdempotencyKey {
  id             String   @id @default(cuid())
  userId         String
  key            String
  requestHash    String
  status         IdempotencyStatus
  responseStatus Int?
  responseBody   Json?
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@unique([userId, key])
  @@index([expiresAt])
}

model RefundRequest {
  id         String              @id @default(cuid())
  orderId    String              @unique
  order      Order               @relation(fields: [orderId], references: [id])
  userId     String
  user       User                @relation("UserRefundRequests", fields: [userId], references: [id])
  status     RefundRequestStatus @default(PENDING)
  reason     String?
  reviewedBy String?
  reviewer   User?               @relation("ReviewedByUser", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([userId])
  @@index([status])
}

model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String
  eventId     String    @unique
  type        String
  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  payload     Json

  @@index([provider])
  @@index([type])
  @@index([processedAt])
}

model Promotion {
  id               String    @id @default(cuid())
  code             String    @unique @db.Citext
  type             PromotionType
  value            BigInt    // basis points for % (1000 = 10.00%), minor units for fixed
  minSubtotalMinor BigInt?   // minimum subtotal required to qualify
  maxUses          Int?      // total usage limit, null = unlimited
  maxUsesPerUser   Int?      // per-user usage limit, null = unlimited
  startsAt         DateTime?
  endsAt           DateTime?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  orders Order[]

  @@index([code])
  @@index([isActive])
  @@index([startsAt, endsAt])
  @@index([createdAt, id])
}

// ─── Phase 2 Infra ───────────────────────────────────────────────────────

// Outbox pattern (P2.3) — durable event store written in the same transaction
// as business state changes. A separate dispatcher (apps/worker) polls
// PENDING rows and enqueues them to BullMQ, then marks SENT.
model Outbox {
  id            String       @id @default(cuid())
  aggregateType String       // e.g. "Order", "Payment"
  aggregateId   String       // the ID of the aggregate root
  eventType     String       // e.g. "OrderCreated", "OrderPaid", "OrderCancelled"
  payload       Json         // event data for the worker handler
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  lastError     String?
  createdAt     DateTime     @default(now())
  sentAt        DateTime?

  @@index([status, createdAt])
}

// Double-entry ledger (P2.4) — every financial event writes paired DEBIT/CREDIT
// entries so sum(debits) === sum(credits) for every transaction batch.
// Uses plain string refs (not relations) to avoid coupling Order/Payment models
// and to support entries without an associated order (e.g. manual adjustments).
model LedgerEntry {
  id          String          @id @default(cuid())
  account     String          // CASH | REVENUE | REFUNDS | FEES | TAX
  direction   LedgerDirection
  amountMinor BigInt
  orderId     String?         // FK-ish to Order.id (no formal relation — append-only audit log)
  paymentId   String?         // FK-ish to Payment.id
  reference   String?         // Stripe PaymentIntent / balance_transaction id
  memo        String?
  createdAt   DateTime        @default(now())

  @@index([orderId])
  @@index([account, createdAt])
}

// Reconciliation report (P2.5) — stores results of nightly Stripe reconciliation
// runs. Each run pulls Stripe balance_transactions since the last cursor and
// compares against local LedgerEntry rows, reporting any drift.
model ReconciliationReport {
  id              String   @id @default(cuid())
  runAt           DateTime @default(now())
  startCursor     String?  // Stripe balance_transaction pagination cursor (last run's endCursor)
  endCursor       String?  // Last cursor from this run (used as startCursor for next run)
  totalStripeAmount  BigInt // sum of Stripe balance_transaction amounts for matched charges
  totalLedgerAmount  BigInt // sum of corresponding LedgerEntry amounts
  driftMinor         BigInt // totalStripeAmount − totalLedgerAmount
  transactionCount   Int    // number of balance_transactions examined
  matchedCount       Int    // number successfully matched to ledger entries
  mismatchedRefs     Json   // [{ reference, stripeAmount, ledgerAmount, drift }]
  createdAt       DateTime @default(now())

  @@index([runAt])
}
